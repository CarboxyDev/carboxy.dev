---
import { Image } from 'astro:assets';
import { ImagePreviewModal } from '@/components/react/ImagePreviewModal';

interface Props {
  images: string[];
  alt: string;
  className?: string;
}

const { images, alt, className } = Astro.props;
---

<div class="image-preview-wrapper">
  <button
    type="button"
    class:list={[
      'focus-ring group relative block w-full cursor-pointer overflow-hidden rounded-lg text-left',
      className
    ]}
    aria-haspopup="dialog"
    aria-label={`Preview ${alt}`}
    data-preview-trigger
  >
    <div class="absolute inset-0 z-10 bg-black/0 transition-all duration-300 group-hover:bg-black/30"></div>
    <div class="absolute inset-0 z-20 flex items-center justify-center opacity-0 transition-all duration-300 group-hover:opacity-100">
      <div class="rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white backdrop-blur-sm">
        Click to preview
      </div>
    </div>
    {images[0] && (
      <Image
        src={`/${images[0]}`}
        alt={alt}
        width={800}
        height={600}
        class="h-full w-full object-contain transition-all duration-300 group-hover:brightness-95"
        loading="lazy"
      />
    )}
  </button>

  <ImagePreviewModal images={images} alt={alt} client:load />
</div>
