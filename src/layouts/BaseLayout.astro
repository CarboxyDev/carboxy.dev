---
import "../styles/global.css";
import { Toaster } from "@/components/ui/toaster";
import { ThemeToggle } from "@/components/react/ThemeToggle";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CarboxyDev",
  description = "I build things for the internet, from polished interfaces to whatever the problem demands. Currently available for freelance and contract work."
} = Astro.props;

const siteUrl = "https://carboxy.dev";
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="CarboxyDev" />
    <meta name="keywords" content="CarboxyDev, software developer, freelance developer, React, Next.js, AI, web development, available for work" />

    <!-- Theme script - prevents FOUC -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (stored === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content="I build things for the internet, from polished interfaces to whatever the problem demands. Currently open for work and contract projects." />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="CarboxyDev" />
    <meta property="og:image" content={`${siteUrl}/logo.png`} />
    <meta property="og:image:width" content="1032" />
    <meta property="og:image:height" content="1032" />
    <meta property="og:image:alt" content="CarboxyDev Logo" />
    <meta property="og:locale" content="en-US" />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="I build things for the internet, from polished interfaces to whatever the problem demands. Open to work and remote opportunities." />
    <meta name="twitter:image" content={`${siteUrl}/logo.png`} />
    <meta name="twitter:creator" content="@carboxydev" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />
  </head>
  <body class="antialiased">
    <ThemeToggle client:load />
    <slot />
    <Toaster client:load />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
